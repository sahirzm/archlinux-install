[include]
  path = ./catppuccin.gitconfig
[alias]
	dag = "log --graph --abbrev-commit --decorate --format=format:'%C(blue)%h%C(reset) - %C(cyan)%aD%C(reset) %C(green)(%ar)%C(reset)%C(yellow)%d%C(reset)%n'' %C(white)%s%C(reset) %C(white)- %an%C(reset)' --all"
	graph = "log --all --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%ci) %C(bold blue)<%an>%Creset'"
[color]
	ui = "auto"
[core]
	excludesFile = "~/.config/git/exclude"
	fileMode = false
	pager = "delta"
[diff]
	tool = "nvimdiff"
[delta]
	navigate = true
	dark = true
	side-by-side = true
	line-numbers = true
  features = catppuccin-mocha
[difftool]
	prompt = true
[difftool "nvimdiff"]
	cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
[interactive]
	diffFilter = "delta --color-only"
[pull]
	rebase = true
[push]
	default = "simple"
[user]
	email = "sahirzm@gmail.com"
	name = "Sahir Maredia"
[init]
	defaultBranch = main
[merge]
  conflictStyle = "zdiff3"
[mergetool]
  prompt = true
  keepBackup = false
[mergetool "nvimdiff"]
  layout = "LOCAL,BASE,REMOTE / MERGED"
