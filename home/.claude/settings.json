{
  "awsAuthRefresh": "aws sso login --profile jobbersoft-bedrock",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_PROFILE": "jobbersoft-bedrock",
    "AWS_REGION": "us-west-2",
    "ANTHROPIC_MODEL": "global.anthropic.claude-sonnet-4-5-20250929-v1:0",
    "ANTHROPIC_SMALL_FAST_MODEL": "global.claude-haiku-4-5-20251001-v1:0",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "16096",
    "MAX_THINKING_TOKENS": "4096",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "jdtls-lsp@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true,
    "superpowers@claude-plugins-official": true
  }
}
