#!/bin/bash

# Display configuration script for Sway
# Usage: display-setup [1|2|3|swap]
# 1    = Laptop only (eDP-1) [default]
# 2    = External displays only (DP-5, DP-6)
# 3    = All displays (eDP-1, DP-5, DP-6)
# swap = Swap positions of the two currently active displays (auto-detected)

MODE=${1:-1}

case $MODE in
1)
  echo "Enabling laptop screen only..."
  swaymsg output eDP-1 disable
  swaymsg output DP-5 disable
  swaymsg output DP-6 disable
  swaymsg output eDP-1 enable
  ;;
2)
  echo "Enabling external displays only..."
  swaymsg output eDP-1 disable
  swaymsg output DP-5 disable
  swaymsg output DP-6 disable
  swaymsg output DP-5 enable pos 0 0
  swaymsg output DP-6 enable pos 2560 0
  ;;
3)
  echo "Enabling all displays..."
  swaymsg output eDP-1 disable
  swaymsg output DP-5 disable
  swaymsg output DP-6 disable
  swaymsg output eDP-1 enable pos 0 0
  swaymsg output DP-5 enable pos 1920 0
  swaymsg output DP-6 enable pos 4480 0
  ;;
swap)
  echo "Swapping display positions..."
  OUTPUTS=$(swaymsg -t get_outputs)
  # Get active outputs sorted by x position (left to right)
  SORTED=$(echo "$OUTPUTS" | jq -r '[.[] | select(.active == true)] | sort_by(.rect.x) | .[] | "\(.name) \(.rect.x) \(.rect.width)"')
  COUNT=$(echo "$SORTED" | wc -l)
  if [ "$COUNT" -ne 2 ]; then
    echo "Error: swap requires exactly 2 active outputs (found $COUNT)"
    exit 1
  fi
  LEFT_NAME=$(echo "$SORTED" | awk 'NR==1 {print $1}')
  LEFT_X=$(echo "$SORTED" | awk 'NR==1 {print $2}')
  LEFT_W=$(echo "$SORTED" | awk 'NR==1 {print $3}')
  RIGHT_NAME=$(echo "$SORTED" | awk 'NR==2 {print $1}')
  RIGHT_W=$(echo "$SORTED" | awk 'NR==2 {print $3}')
  # Place the right monitor at x=0, left monitor adjacent to it
  swaymsg output "$RIGHT_NAME" pos "$LEFT_X" 0
  swaymsg output "$LEFT_NAME" pos "$RIGHT_W" 0
  ;;
*)
  echo "Error: Invalid option '$1'"
  echo "Usage: $0 [1|2|3|swap]"
  exit 1
  ;;
esac

echo "Display configuration complete."
